# Database
# SQLite (development):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/account_vault"

# Enkripsi AES-256 — harus 32 bytes / 64 hex chars
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-string-here"

# Iron Session secret — minimal 32 chars
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="your-session-secret-here"

# Node environment
NODE_ENV="production"
